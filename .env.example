# Network: devnet | testnet | mainnet-beta
NETWORK=devnet

# Optional: override RPC endpoint (defaults to public endpoint for NETWORK)
# RPC_URL=https://your-custom-rpc.com

# House wallet private key (base58, 64 bytes)
# Generate one: uv run coinflip-new-wallet
HOUSE_PRIVATE_KEY=

# Player win probability (default 0.49 = 49%)
# Range: 0.01 ~ 0.99. Lower = more house edge.
WIN_PROBABILITY=0.49

# Minimum bet in lamports (default 1000000 = 0.001 SOL)
MIN_BET_LAMPORTS=1000000

# Transaction poll interval in seconds
POLL_INTERVAL_SECONDS=5
